  "keyFeatures": [
    "Async document processing pipeline for construction drawings, specs, and documents",
    "Normalized JSON output with structured sheets, regions, specifications, and docs",
    "Semantic source search across projects and individual project sources",
    "Multi-mode file upload: multipart form, signed direct PUT, and multipart signed",
    "Per-page credit billing with separate rates for drawings and documents",
    "Webhook notifications and idempotent job creation",
    "Short-lived unauthenticated artifact download tokens",
    "Workspace API key management with scoped permissions"
